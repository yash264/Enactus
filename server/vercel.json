{
    "version": 2,
    "builds": [
        {
            "src": "src/app.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "src/app.js"
        }
    ],
    "headers": [
        {
            "source": "/news/fetchNews",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "https://enactus-meta.vercel.app"
                },
                {
                    "key": "Access-Control-Allow-Methods",
                    "value": "GET, OPTIONS"
                }
            ]
        }
    ]
}